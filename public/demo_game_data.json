        "happy": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/小林悠/happy.png",
        "surprised": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/小林悠/surprised.png",
        "thoughtful": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/小林悠/thoughtful.png"
      }
    },
    "partner": {
      "name": "小樱",
      "color": "#FFB6C1",
      "expressions": {
        "normal": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/雪村千雪/normal.png",
        "happy": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/雪村千雪/soft_smile.png",
        "sad": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/雪村千雪/sad.png",
        "surprised": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/characters/雪村千雪/surprised.png"
