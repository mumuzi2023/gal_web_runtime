  "scenes": {
    "intro": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_classroom_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "引导", "subtitle": "欢迎体验" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_classroom_day.jpg", "transition": "fade" },
        { "type": "narration", "text": "欢迎来到 GalGame 运行时引擎的功能引导演示。请点击屏幕推进对话。" },
        { "type": "show", "character": "guide", "expression": "normal", "position": "center" },
        { "type": "dialog", "character": "guide", "text": "你好！我是向导。接下来我会带你体验引擎的核心功能。", "expression": "normal" },
        { "type": "dialog", "character": "guide", "text": "首先，你看到的是【对话系统】——文字正在一个字一个字地出现，这就是打字机效果。", "expression": "happy" },
        { "type": "narration", "text": "（这是一段旁白。旁白没有角色名称，用于描述场景或内心独白。）" },
        { "type": "dialog", "character": "guide", "text": "注意对话框上方的按钮：「自动」可以自动推进，「记录」查看历史对话，「存档」保存进度，「进度」查看流程图，「菜单」打开设置。", "expression": "thoughtful" },
        { "type": "dialog", "character": "guide", "text": "现在让我们试试【多角色同屏】和【表情切换】。", "expression": "normal" },
        { "type": "show", "character": "partner", "expression": "normal", "position": "right" },
        { "type": "show", "character": "guide", "expression": "happy", "position": "left" },
        { "type": "dialog", "character": "partner", "text": "大家好！我是小樱，负责配合演示～", "expression": "happy" },
        { "type": "dialog", "character": "guide", "text": "注意看：正在说话的角色会高亮，其他角色会稍微暗淡。", "expression": "normal" },
        { "type": "dialog", "character": "partner", "text": "现在轮到我说话了，所以向导那边变暗了对吧？", "expression": "normal" },
        { "type": "narration", "text": "接下来将进入【选择分支】功能测试。你的选择将决定后续剧情走向。" },
        { "type": "dialog", "character": "guide", "text": "请在下面的选项中做出你的选择——只有点击选项才能继续，点击其他地方不会跳过。", "expression": "thoughtful" },
        {
          "type": "choice",
          "options": [
            { "text": "去图书馆看看", "jump": "library_scene", "set": { "route": "library" } },
            { "text": "去天台吹风", "jump": "rooftop_scene", "set": { "route": "rooftop" } }
          ]
        }
      ]
    },
    "library_scene": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_library_window_nook_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第二章", "subtitle": "图书馆路线" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_library_window_nook_day.jpg", "transition": "fade" },
        { "type": "hide", "character": "partner" },
        { "type": "show", "character": "guide", "expression": "happy", "position": "center" },
        { "type": "dialog", "character": "guide", "text": "你选择了图书馆路线！背景已经切换了，注意淡入过渡效果。", "expression": "happy" },
        { "type": "effect", "name": "sakura", "enable": true },
        { "type": "dialog", "character": "guide", "text": "现在开启了【樱花粒子特效】，画面上会飘落樱花花瓣。", "expression": "normal" },
        { "type": "shake", "duration": 500, "intensity": 3 },
        { "type": "dialog", "character": "guide", "text": "刚才那是【画面震动】效果，用于表现惊讶或冲击的场景。", "expression": "surprised" },
        { "type": "narration", "text": "现在建议你试试以下功能：\n1. 点击「存档」保存当前进度\n2. 点击「记录」查看之前的对话历史\n3. 点击「进度」查看流程图" },
        { "type": "dialog", "character": "guide", "text": "测试完毕后，继续点击推进到结局。", "expression": "thoughtful" },
        { "type": "jump", "target": "ending_good" }
      ]
    },
    "rooftop_scene": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第二章", "subtitle": "天台路线" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg", "transition": "fade" },
        { "type": "hide", "character": "guide" },
        { "type": "show", "character": "partner", "expression": "happy", "position": "center" },
        { "type": "dialog", "character": "partner", "text": "你选了天台路线！这里的背景是傍晚的天台。", "expression": "happy" },
        { "type": "wait", "duration": 800 },
        { "type": "dialog", "character": "partner", "text": "刚才有一小段等待停顿，那是【wait 指令】在起作用。", "expression": "normal" },
        { "type": "flash", "color": "#ffffff", "duration": 400 },
        { "type": "dialog", "character": "partner", "text": "看到闪白了吗？那是【闪屏特效】，常用于回忆或转场。", "expression": "surprised" },
        { "type": "narration", "text": "建议你现在试试：\n1. 点击「存档」保存进度\n2. 点击「记录」查看对话历史\n3. 点击「进度」查看当前解锁的章节" },
        { "type": "dialog", "character": "partner", "text": "好了，让我们前往结局吧！", "expression": "happy" },
        { "type": "jump", "target": "ending_good" }
      ]
    },
    "ending_good": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_festival_venue_evening.jpg",
      "commands": [
        { "type": "chapter_title", "text": "终章", "subtitle": "功能测试完成" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_festival_venue_evening.jpg", "transition": "fade" },
        { "type": "show", "character": "guide", "expression": "happy", "position": "left" },
        { "type": "show", "character": "partner", "expression": "happy", "position": "right" },
        { "type": "dialog", "character": "guide", "text": "恭喜你完成了所有功能的体验！", "expression": "happy" },
        { "type": "dialog", "character": "partner", "text": "回到标题画面后，可以在「结局列表」中看到已达成的结局哦～", "expression": "happy" },
        { "type": "narration", "text": "引导演示到此结束。感谢体验！" },
        { "type": "end", "ending_id": "complete" }
      ]
    }
  },
  "variables": {
    "route": ""
  },
  "endings": {
    "complete": {
      "name": "引导完成 —— 全功能体验",
      "condition": "true"
    }
  },
  "start_scene": "intro",
  "scene_order": [
    "intro",
    "library_scene",
    "rooftop_scene",
    "ending_good"
  ]
}
