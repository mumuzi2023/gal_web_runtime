  "scenes": {
    "chapter1_classroom": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_classroom_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第一章", "subtitle": "初遇的教室" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_classroom_day.jpg", "transition": "fade" },
        { "type": "sakura", "enable": true },
        { "type": "narration", "text": "九月的阳光透过玻璃窗洒在课桌上，空气中弥漫着新书本的墨香。林星辰站在教室门口，手里攥着转学通知单，深吸了一口气。" },
        { "type": "show", "character": "lin_xingchen", "expression": "worried", "position": "center" },
        { "type": "dialog", "character": "lin_xingchen", "text": "（这就是星海学园的教室吗……比想象中要宽敞许多。）", "expression": "worried" },
        { "type": "wait", "duration": 800 },
        { "type": "narration", "text": "一道明快的声音打断了他的思绪——" },
        { "type": "show", "character": "su_wanqing", "expression": "happy", "position": "left" },
        { "type": "dialog", "character": "su_wanqing", "text": "你好呀！你就是今天新来的转学生吧？我叫苏晚晴，是班长！有什么不懂的尽管问我～", "expression": "happy" },
        { "type": "dialog", "character": "lin_xingchen", "text": "你、你好……我是林星辰，请多多关照。", "expression": "surprised" },
        { "type": "wait", "duration": 600 },
        { "type": "narration", "text": "就在这时，坐在窗边的一个女生缓缓合上手中的书卷，冷淡地扫了一眼这边。" },
        { "type": "show", "character": "ye_lingfeng", "expression": "cold", "position": "right" },
        { "type": "dialog", "character": "ye_lingfeng", "text": "……又来一个吵闹的人。", "expression": "cold" },
        { "type": "dialog", "character": "su_wanqing", "text": "叶凌风！你每次都这样，人家会害怕的啦！", "expression": "worried" },
        { "type": "dialog", "character": "ye_lingfeng", "text": "我只是说了事实。", "expression": "cold" },
        { "type": "wait", "duration": 500 },
        { "type": "narration", "text": "午休铃声响起。苏晚晴热情地提议一起去食堂，而叶凌风则默默收拾书包准备去图书馆。走廊尽头，学生会副会长陈瑶瑶抱着一叠文件匆匆走过，眉头微蹙。" },
        { "type": "show", "character": "chen_yaoyao", "expression": "serious", "position": "center" },
        { "type": "hide", "character": "chen_yaoyao" },
        { "type": "set", "character": "lin_xingchen", "expression": "thoughtful" },
        { "type": "wait", "duration": 800 },
        {
          "type": "choice",
          "options": [
            { "text": "和苏晚晴去食堂", "jump": "chapter2_cafeteria", "set": { "affection_wanqing": "+2", "empathy": "+1" } },
            { "text": "跟叶凌风去图书馆", "jump": "chapter2_library", "set": { "affection_lingfeng": "+2", "empathy": "+1" } },
            { "text": "追上陈瑶瑶帮忙", "jump": "chapter2_rooftop", "set": { "affection_yaoyao": "+2", "empathy": "+1" } }
          ]
        }
      ]
    },
    "chapter2_cafeteria": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_cafeteria_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第二章", "subtitle": "食堂的秘密" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_cafeteria_day.jpg", "transition": "fade" },
        { "type": "show", "character": "lin_xingchen", "expression": "normal", "position": "left" },
        { "type": "show", "character": "su_wanqing", "expression": "happy", "position": "right" },
        { "type": "dialog", "character": "su_wanqing", "text": "今天的特制咖喱饭超好吃的！你一定要试试！", "expression": "happy" },
        { "type": "dialog", "character": "lin_xingchen", "text": "谢谢推荐，看起来确实很不错。", "expression": "normal" },
        { "type": "wait", "duration": 600 },
        { "type": "narration", "text": "吃到一半的时候，苏晚晴突然安静了下来，手里的筷子不自觉地停住了。" },
        { "type": "show", "character": "su_wanqing", "expression": "sad", "position": "right" },
        { "type": "dialog", "character": "lin_xingchen", "text": "晚晴……你还好吗？", "expression": "worried" },
        { "type": "shake", "duration": 300, "intensity": 2 },
        { "type": "dialog", "character": "su_wanqing", "text": "没事啦……只是想到家里的事情。爸爸妈妈最近经常吵架，每天晚上回到家都是冷冰冰的气氛。我总是在学校装作很开心的样子，但其实……有点累了。", "expression": "sad" },
        { "type": "wait", "duration": 1200 },
        {
          "type": "choice",
          "options": [
            { "text": "「我会一直陪着你，我们一起面对」", "set": { "empathy": "+2", "affection_wanqing": "+4" }, "jump": "chapter3_festival" },
            { "text": "「别担心，一切都会好起来的」", "set": { "affection_wanqing": "+2" }, "jump": "chapter3_festival" }
          ]
        }
      ]
    },
    "chapter2_library": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_library_window_nook_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第二章", "subtitle": "图书馆的告白" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_library_window_nook_day.jpg", "transition": "fade" },
        { "type": "show", "character": "ye_lingfeng", "expression": "cold", "position": "center" },
        { "type": "show", "character": "lin_xingchen", "expression": "normal", "position": "left" },
        { "type": "dialog", "character": "ye_lingfeng", "text": "你怎么跟来了？图书馆是安静的地方，不要打扰别人。", "expression": "cold" },
        { "type": "dialog", "character": "lin_xingchen", "text": "我也想看看书而已。你在看什么呢？", "expression": "normal" },
        { "type": "dialog", "character": "ye_lingfeng", "text": "……《星与海之间》。一个关于孤独旅人寻找归宿的故事。", "expression": "normal" },
        { "type": "wait", "duration": 800 },
        { "type": "narration", "text": "叶凌风翻着书页的手指微微颤抖，眼眸中闪过一丝不易察觉的悲伤。" },
        { "type": "show", "character": "ye_lingfeng", "expression": "sad", "position": "center" },
        { "type": "dialog", "character": "ye_lingfeng", "text": "……去年，我最好的朋友背叛了我。她把我写的小说署上自己的名字发到了网上，还告诉所有人是我抄袭她的。从那以后我就再也不相信任何人了。", "expression": "sad" },
        { "type": "wait", "duration": 1500 },
        {
          "type": "choice",
          "options": [
            { "text": "「我不会离开你，我们一起面对过去」", "set": { "empathy": "+2", "affection_lingfeng": "+4" }, "jump": "chapter3_festival" },
            { "text": "「时间会治愈一切的」", "set": { "affection_lingfeng": "+2" }, "jump": "chapter3_festival" }
          ]
        }
      ]
    },
    "chapter2_rooftop": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第二章", "subtitle": "天台的重担" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg", "transition": "fade" },
        { "type": "show", "character": "chen_yaoyao", "expression": "tired", "position": "right" },
        { "type": "show", "character": "lin_xingchen", "expression": "worried", "position": "left" },
        { "type": "dialog", "character": "lin_xingchen", "text": "陈学姐！需要帮忙搬这些文件吗？看起来好重……", "expression": "worried" },
        { "type": "dialog", "character": "chen_yaoyao", "text": "不用了，我自己能行。", "expression": "serious" },
        { "type": "wait", "duration": 500 },
        { "type": "narration", "text": "但她的脚步明显有些踉跄，几份文件差点从臂弯中滑落。林星辰上前接住了即将掉落的文件夹。" },
        { "type": "dialog", "character": "chen_yaoyao", "text": "……谢谢。其实我弟弟最近住院了，家里的经济压力很大。学生会的工作又不能丢下……我已经好几天没怎么睡觉了。", "expression": "tired" },
        { "type": "shake", "duration": 400, "intensity": 3 },
        { "type": "wait", "duration": 1200 },
        {
          "type": "choice",
          "options": [
            { "text": "「让我来分担你的重担吧」", "set": { "empathy": "+2", "affection_yaoyao": "+4" }, "jump": "chapter3_festival" },
            { "text": "「你已经很努力了，不用勉强自己」", "set": { "affection_yaoyao": "+2" }, "jump": "chapter3_festival" }
          ]
        }
      ]
    },
    "chapter3_festival": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_festival_venue_evening.jpg",
      "commands": [
        { "type": "chapter_title", "text": "第三章", "subtitle": "学园祭的黄昏" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_festival_venue_evening.jpg", "transition": "fade" },
        { "type": "sakura", "enable": true },
        { "type": "narration", "text": "学园祭的傍晚，灯笼在微风中轻轻摇曳，空气中弥漫着烤玉米和棉花糖的香甜气味。舞台上传来轻快的音乐，同学们三三两两地穿梭在各个摊位之间。" },
        { "type": "show", "character": "su_wanqing", "expression": "worried", "position": "left" },
        { "type": "dialog", "character": "su_wanqing", "text": "糟了！红豆馅用完了，还有一大排人在等我们的鲷鱼烧呢……", "expression": "worried" },
        { "type": "wait", "duration": 600 },
        { "type": "show", "character": "ye_lingfeng", "expression": "sad", "position": "right" },
        { "type": "narration", "text": "叶凌风独自守着文学社的书展摊位，几个旧日的同学正在嘲笑她选的书。她的手指紧紧攥着书脊，指节泛白。" },
        { "type": "wait", "duration": 600 },
        { "type": "show", "character": "chen_yaoyao", "expression": "tired", "position": "center" },
        { "type": "dialog", "character": "chen_yaoyao", "text": "小翔，再忍一下……医务室就在前面。姐姐的药应该带了才对……", "expression": "tired" },
        { "type": "narration", "text": "陈瑶瑶背着发烧的弟弟，脚步沉重地穿过人群。三个方向，三份牵挂，林星辰必须做出选择。" },
        { "type": "wait", "duration": 800 },
        {
          "type": "choice",
          "options": [
            { "text": "立刻去帮苏晚晴解围", "set": { "empathy": "+3" }, "jump": "ending_seaside" },
            { "text": "先完成自己的事再说", "jump": "ending_cliff" },
            { "text": "冲过去替叶凌风挡住那些人", "set": { "empathy": "+3" }, "jump": "ending_seaside" },
            { "text": "等那些人走了再去安慰她", "jump": "ending_cliff" },
            { "text": "跑去帮陈瑶瑶背弟弟去医务室", "set": { "empathy": "+3" }, "jump": "ending_seaside" },
            { "text": "忙完手头的工作再去找她", "jump": "ending_cliff" }
          ]
        }
      ]
    },
    "ending_seaside": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_cafeteria_day.jpg",
      "commands": [
        { "type": "chapter_title", "text": "终章", "subtitle": "海边的约定" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg", "transition": "fade" },
        { "type": "sakura", "enable": true },
        { "type": "narration", "text": "夕阳将天空染成了一片温柔的橙红色，海浪轻轻拍打着礁石。放学后，林星辰独自来到了海边的小路上，等待着那个约定好的人。" },
        { "type": "wait", "duration": 1500 },
        {
          "type": "if",
          "condition": "affection_wanqing > affection_lingfeng and affection_wanqing > affection_yaoyao",
          "then": [
            { "type": "show", "character": "su_wanqing", "expression": "happy", "position": "center" },
            { "type": "dialog", "character": "su_wanqing", "text": "星辰……谢谢你一直陪在我身边。因为有你，我终于有勇气面对家里的一切了。", "expression": "happy" },
            { "type": "dialog", "character": "lin_xingchen", "text": "晚晴，从今以后不管遇到什么事，我都会在你身边。", "expression": "happy" },
            { "type": "set", "variable": "affection_wanqing", "value": "+4" }
          ],
          "else": {
            "type": "if",
            "condition": "affection_lingfeng > affection_wanqing and affection_lingfeng > affection_yaoyao",
            "then": [
              { "type": "show", "character": "ye_lingfeng", "expression": "smile", "position": "center" },
              { "type": "dialog", "character": "ye_lingfeng", "text": "……我给你带了这本书。扉页上写了一些话，是我一直想对你说的。", "expression": "smile" },
              { "type": "dialog", "character": "lin_xingchen", "text": "凌风，谢谢你愿意打开心扉。从今以后，让我成为你的归宿。", "expression": "thoughtful" },
              { "type": "set", "variable": "affection_lingfeng", "value": "+4" }
            ],
            "else": [
              { "type": "show", "character": "chen_yaoyao", "expression": "smile", "position": "center" },
              { "type": "dialog", "character": "chen_yaoyao", "text": "你总是在我最脆弱的时候出现……我不知道该怎么感谢你才好。", "expression": "smile" },
              { "type": "dialog", "character": "lin_xingchen", "text": "瑶瑶学姐，你不需要独自承担一切。让我和你一起扛下去。", "expression": "normal" },
              { "type": "set", "variable": "affection_yaoyao", "value": "+4" }
            ]
          }
        },
        { "type": "wait", "duration": 2000 },
        { "type": "narration", "text": "夕阳缓缓沉入海平面，天边最后一缕金光洒在两人身上。海风轻抚着他们的发丝，带走了所有的不安和忧愁。在这一刻，整个世界仿佛都安静了下来，只剩下海浪声和彼此的心跳。" },
        { "type": "wait", "duration": 1500 },
        { "type": "end", "ending_id": "good_ending" }
      ]
    },
    "ending_cliff": {
      "background": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg",
      "commands": [
        { "type": "chapter_title", "text": "终章", "subtitle": "独自的黄昏" },
        { "type": "bg", "src": "https://storyforge.r2.it-bill.com/projects/019d8c1c-e4cb-77f1-8133-9fc8ff971812/backgrounds/sakura_academy_rooftop_terrace_evening.jpg", "transition": "fade" },
        { "type": "narration", "text": "学园祭结束后的天台，只剩林星辰一个人站在护栏旁。远处的海面倒映着晚霞，美得不真实。" },
        { "type": "show", "character": "lin_xingchen", "expression": "thoughtful", "position": "center" },
        { "type": "wait", "duration": 1000 },
        { "type": "narration", "text": "他回想起今天发生的一切——三个女孩各自的困境，自己犹豫不决的选择。也许在最关键的时刻，他没能伸出那双手。" },
